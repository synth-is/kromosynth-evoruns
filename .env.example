# Evorun Browser Server Configuration

# =============================================================================
# Server
# =============================================================================

# Port the server listens on (default: 3004)
PORT=3004

# =============================================================================
# Directory Paths
# =============================================================================

# Root directory containing local evorun folders
# Each subfolder should be named with a ULID prefix, e.g. 01KG..._myrun
EVORUN_ROOT_DIR=/Users/bjornpjo/Developer/apps/synth.is/kromosynth-cli/cli-app/evoruns

# Root directory for pre-rendered WAV files (evorenders)
EVORENDERS_ROOT_DIR=/Users/bjornpjo/Developer/apps/synth.is/kromosynth-cli/cli-app/evorenders

# Optional: additional directory for evoruns synced from remote workers via SyncManager
# If unset, sync endpoint storage falls back to EVORUN_ROOT_DIR
# SYNC_ROOT_DIR=/data/evorun-sync

# =============================================================================
# Display
# =============================================================================

# Granularity for grouping evoruns by date in the summary endpoint
# Options: month | week | day (default: month)
DATE_GRANULARITY=month

# =============================================================================
# Sync API (receiving data from remote evolution-manager workers)
# =============================================================================
# See kromosynth-services/SYNC-PLAN.md for full architecture documentation.

# Comma-separated list of accepted API keys for the /api/sync/* endpoints.
# If empty, sync endpoints are disabled (return 503).
# Workers must send the matching key in the X-Sync-API-Key request header.
# SYNC_API_KEYS=your-secret-key-here,another-key-for-another-worker
